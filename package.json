{
  "name": "beacon",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "Beacon \u2014 a patient-first clinical trial finder. Free forever. Your data never leaves your device.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "vite-node scripts/e2e-live.ts",
    "seo": "vite-node scripts/generate-seo.ts",
    "build:launch": "npm run build && npm run seo"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "playwright-core": "^1.61.1",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
